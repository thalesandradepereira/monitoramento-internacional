# === IA (Gemini — grátis) ===
# Chave do Google AI Studio (a mesma que você usa na Agenda serve).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === Para quem enviar o resumo ===
# (Valor REAL fica no GitHub Secret DEST_EMAIL, não aqui. Isto é só exemplo.)
# Vários destinos: separe por vírgula. Ex.: alguem@x.com, outro@y.com
DEST_EMAIL=seu-email@exemplo.com

# === Como enviar o e-mail (SMTP) ===
# Opção mais fácil: Gmail com "Senha de app" (não é sua senha normal).
#   1. Ative a verificação em 2 etapas na sua conta Google
#   2. Gere uma "Senha de app" em https://myaccount.google.com/apppasswords
#   3. Use seu Gmail em SMTP_USER e a senha de app (16 letras) em SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seu-email@gmail.com
SMTP_PASS=senha-de-app-de-16-letras
# Nome/remetente que aparece no e-mail
FROM_NAME=Resumo IA

# === Agendamento ===
# Horário diário (cron). Padrão: 04:00 BRT. Fuso de referência abaixo.
CRON_EXPR=0 4 * * *
TIMEZONE=America/Sao_Paulo

# Quantos tópicos no máximo
MAX_TOPICOS=10
# Janela de notícias (horas)
JANELA_HORAS=24

# === Descadastro automático (opcional) ===
# URL do Cloudflare Worker de descadastro (após deploy)
UNSUBSCRIBE_WORKER_URL=https://resumo-ia-unsub.SEU-USUARIO.workers.dev
# Chave secreta compartilhada (HMAC) — gere uma aleatória e use a mesma no Worker
UNSUBSCRIBE_SECRET=
